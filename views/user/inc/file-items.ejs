<% if(files.length===0) { %>
    <img src="/img/no files.png" alt="no files" height="588px" width="687px"
        style="object-fit: cover; margin: 0 11rem;">
    <% } else { %>
        <thead>
            <tr>
                <th>Filename</th>
                <th>Size</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% files.forEach(file=> { %>
                <tr>
                    <td>
                        <%= file.name %>
                    </td>
                    <td>
                        <%= file.sizeMB %> MB
                    </td>
                    <td>
                        <button class="btn download"><a href="download/<%= file._id %>">Download</a></button>
                        <button class="btn download"><a href="view/<%= file._id %>">View</a></button>
                        <button class="btn delete"><a href="delete/<%= file._id %>">Delete</a></button>
                    </td>
                </tr>
                <% }) %>
        </tbody>
        <% } %>